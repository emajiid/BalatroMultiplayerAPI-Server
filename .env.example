PORT=8788
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bmp

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# Steam
STEAM_WEB_API_KEY=your-steam-web-api-key
STEAM_APP_ID=2379780

# Discord OAuth2
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:8788/api/auth/discord/callback

# EMQX
EMQX_BROKER_URL=mqtt://emqx:1883
EMQX_SYSTEM_CLIENT_ID=bmp-api-server
EMQX_SYSTEM_USERNAME=bmp-system
EMQX_SYSTEM_PASSWORD=change-me-in-production

# Player identity (used to hash Steam/Discord IDs before storage — never expose or rotate this)
PLAYER_ID_SALT=change-me-use-at-least-32-random-chars

# Admin endpoint secret (POST /admin/refresh-config)
ADMIN_SECRET=change-me-use-at-least-32-random-chars

# XLM-RoBERTa moderation sidecar (set by docker-compose via service name)
# Leave empty to disable ML moderation and use regex-only mode.
MODERATION_SERVICE_URL=http://moderation:8001
MODERATION_TIMEOUT_MS=2000
# When 'true', messages pass through if the sidecar is unreachable.
# Set to 'false' once the service is confirmed stable in production.
MODERATION_FALLBACK_ALLOW=true
