DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bmp

# Must match the value used by the API server
PLAYER_ID_SALT=change-me-use-at-least-32-random-chars

# Signs the web session cookie — separate from the API's JWT_SECRET
SESSION_SECRET=change-me-in-production

# Public URL of this web app (used as OpenID return realm)
PUBLIC_BASE_URL=http://localhost:5173
